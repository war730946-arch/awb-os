{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile",
    "buildArgs": {
      "CACHEBUST": "1"
    }
  },
  "deploy": {
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ALWAYS",
    "healthcheckTimeout": 300
  }
}
